{
  "name": "styleport-platform",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node node_modules/prisma/build/index.js generate",
    "build": "next build",
    "start": "node server.js",
    "start:hostinger": "node server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "node node_modules/prisma/build/index.js generate",
    "prisma:migrate": "node node_modules/prisma/build/index.js migrate dev",
    "prisma:deploy": "node node_modules/prisma/build/index.js migrate deploy",
    "prisma:status": "node node_modules/prisma/build/index.js migrate status",
    "prisma:seed": "node node_modules/prisma/build/index.js db seed",
    "prisma:studio": "node node_modules/prisma/build/index.js studio",
    "validate:env:production": "tsx scripts/validate-production-env.ts",
    "prepare:production": "npm run validate:env:production && npm run prisma:generate && npm run prisma:deploy && npm run build",
    "deploy:hostinger": "sh ./scripts/hostinger-deploy.sh"
  },
  "postinstall": "node node_modules/prisma/build/index.js generate",
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.0",
    "@prisma/client": "^6.17.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19.2.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^6.34.0",
    "prisma": "^6.17.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4",
    "tesseract.js": "^7.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "vitest": "^4.1.4"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
