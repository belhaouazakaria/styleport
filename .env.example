# ============================================================
# LOCAL DEVELOPMENT ENVIRONMENT (safe placeholders only)
# ============================================================
# Copy to `.env.local` for local development.
# For production, use `.env.production.example` as reference.

NODE_ENV=development

# ------------------------------------------------------------
# Core app URLs
# ------------------------------------------------------------
APP_BASE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_strong_random_secret_at_least_32_chars

# ------------------------------------------------------------
# Share image storage (server-side pre-generated Pinterest pins)
# ------------------------------------------------------------
# Optional override for generated image files.
# Defaults to: <project>/public/generated/pins
SHARE_IMAGE_STORAGE_DIR=
# Optional public URL prefix that maps to SHARE_IMAGE_STORAGE_DIR content.
# Defaults to: /generated/pins
SHARE_IMAGE_PUBLIC_PATH_PREFIX=/generated/pins

# ------------------------------------------------------------
# Database (external PostgreSQL)
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/styleport

# ------------------------------------------------------------
# OpenAI (server-only)
# ------------------------------------------------------------
OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# ------------------------------------------------------------
# Public branding (safe to expose in browser)
# ------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=What Type Of | Translator

# ------------------------------------------------------------
# Admin bootstrap (dev/local only defaults)
# ------------------------------------------------------------
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=ChangeMe123!

# ------------------------------------------------------------
# Usage protection and emergency shutdown
# ------------------------------------------------------------
USAGE_PROTECTION_ENABLED=true
IP_RATE_LIMIT_PER_MINUTE=5
IP_RATE_LIMIT_PER_HOUR=50
IP_RATE_LIMIT_PER_DAY=200
GLOBAL_DAILY_TOKEN_CAP=200000
AUTO_EMERGENCY_SHUTDOWN_ENABLED=true
TRUST_PROXY_HEADERS=true
IP_HASH_SECRET=replace_with_random_secret_min_16_chars

# ------------------------------------------------------------
# Alerting / email (Brevo)
# ------------------------------------------------------------
ALERT_ADMIN_EMAIL=alerts@example.com
EMAIL_FROM=What Type Of | Translator <translate@whattypeof.com>
BREVO_API_KEY=replace_with_brevo_api_key
