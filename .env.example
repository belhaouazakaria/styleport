# ============================================================
# LOCAL DEVELOPMENT ENVIRONMENT (safe placeholders only)
# ============================================================
# Copy to `.env.local` for local development.
# For production, use `.env.production.example` as reference.

NODE_ENV=development

# ------------------------------------------------------------
# Core app URLs
# ------------------------------------------------------------
APP_BASE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_strong_random_secret_at_least_32_chars

# ------------------------------------------------------------
# Database (external PostgreSQL)
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/styleport

# ------------------------------------------------------------
# OpenAI (server-only)
# ------------------------------------------------------------
OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# ------------------------------------------------------------
# Public branding (safe to expose in browser)
# ------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=StylePort

# ------------------------------------------------------------
# Admin bootstrap (dev/local only defaults)
# ------------------------------------------------------------
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=ChangeMe123!

# ------------------------------------------------------------
# Request form anti-spam (Cloudflare Turnstile)
# ------------------------------------------------------------
# NEXT_PUBLIC_* is safe for browser usage.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace_with_turnstile_site_key
TURNSTILE_SECRET_KEY=replace_with_turnstile_secret_key

# ------------------------------------------------------------
# Usage protection and emergency shutdown
# ------------------------------------------------------------
USAGE_PROTECTION_ENABLED=true
IP_RATE_LIMIT_PER_MINUTE=5
IP_RATE_LIMIT_PER_HOUR=50
IP_RATE_LIMIT_PER_DAY=200
GLOBAL_DAILY_TOKEN_CAP=200000
AUTO_EMERGENCY_SHUTDOWN_ENABLED=true
TRUST_PROXY_HEADERS=true
IP_HASH_SECRET=replace_with_random_secret_min_16_chars

# ------------------------------------------------------------
# Alerting / email (Resend)
# ------------------------------------------------------------
ALERT_ADMIN_EMAIL=alerts@example.com
EMAIL_FROM=StylePort Alerts <alerts@example.com>
RESEND_API_KEY=replace_with_resend_api_key
