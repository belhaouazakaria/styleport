# ============================================================
# PRODUCTION ENVIRONMENT (Hostinger Node.js Web App)
# Domain example: https://translators.yourdomain.com
# ============================================================
# Copy to `.env.production` and replace every placeholder.
# Never commit real secrets.

NODE_ENV=production

# ------------------------------------------------------------
# Core app URLs (production HTTPS subdomain)
# ------------------------------------------------------------
APP_BASE_URL=https://translators.yourdomain.com
NEXTAUTH_URL=https://translators.yourdomain.com
NEXTAUTH_SECRET=replace_with_strong_random_secret_at_least_32_chars

# ------------------------------------------------------------
# External managed PostgreSQL (Supabase/Neon/Prisma Postgres)
# ------------------------------------------------------------
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require

# ------------------------------------------------------------
# OpenAI (server-only)
# ------------------------------------------------------------
OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# ------------------------------------------------------------
# Public branding (safe for client exposure)
# ------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=StylePort

# ------------------------------------------------------------
# Admin bootstrap (used by seed command only)
# ------------------------------------------------------------
ADMIN_SEED_EMAIL=admin@yourdomain.com
ADMIN_SEED_PASSWORD=replace_with_strong_initial_password

# ------------------------------------------------------------
# Request anti-spam (Cloudflare Turnstile)
# ------------------------------------------------------------
# Safe public variable:
NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace_with_turnstile_site_key
# Server-only secret:
TURNSTILE_SECRET_KEY=replace_with_turnstile_secret_key

# ------------------------------------------------------------
# Usage protection and emergency shutdown
# ------------------------------------------------------------
USAGE_PROTECTION_ENABLED=true
IP_RATE_LIMIT_PER_MINUTE=5
IP_RATE_LIMIT_PER_HOUR=50
IP_RATE_LIMIT_PER_DAY=200
GLOBAL_DAILY_TOKEN_CAP=200000
AUTO_EMERGENCY_SHUTDOWN_ENABLED=true
TRUST_PROXY_HEADERS=true
IP_HASH_SECRET=replace_with_random_secret_min_16_chars

# ------------------------------------------------------------
# Alerting / email (Resend)
# ------------------------------------------------------------
ALERT_ADMIN_EMAIL=alerts@yourdomain.com
EMAIL_FROM=StylePort Alerts <alerts@yourdomain.com>
RESEND_API_KEY=replace_with_resend_api_key
