# ============================================================
# PRODUCTION ENVIRONMENT (Hostinger Node.js Web App)
# Domain: https://translators.whattypeof.com
# ============================================================
# Copy to `.env.production` and replace every placeholder.
# Never commit real secrets.

NODE_ENV=production

# ------------------------------------------------------------
# Core app URLs (production HTTPS subdomain)
# ------------------------------------------------------------
# Important: use your real public domain. Do NOT use localhost or 0.0.0.0 here.
APP_BASE_URL=https://translators.whattypeof.com
NEXT_PUBLIC_APP_URL=https://translators.whattypeof.com
NEXTAUTH_URL=https://translators.whattypeof.com
NEXTAUTH_SECRET=replace_with_strong_random_secret_at_least_32_chars

# ------------------------------------------------------------
# Share image storage (pre-generated Pinterest share images)
# ------------------------------------------------------------
# Optional absolute server path for generated pin images.
# Default: <app-root>/public/generated/pins
SHARE_IMAGE_STORAGE_DIR=
# Public path prefix that maps to generated image files.
SHARE_IMAGE_PUBLIC_PATH_PREFIX=/generated/pins

# ------------------------------------------------------------
# External managed PostgreSQL (Supabase/Neon/Prisma Postgres)
# ------------------------------------------------------------
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require

# ------------------------------------------------------------
# OpenAI (server-only)
# ------------------------------------------------------------
OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
GOOGLE_INDEXING_ENABLED=false
GOOGLE_INDEXING_DRY_RUN=false
# Google Indexing API credentials
# Recommended method:
# client_email -> GOOGLE_CLIENT_EMAIL
# project_id   -> GOOGLE_PROJECT_ID
# private_key  -> GOOGLE_PRIVATE_KEY_BASE64 (base64-encoded)
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_PRIVATE_KEY_BASE64=replace_with_base64_encoded_private_key

# Fallback only (less reliable on some hosts):
GOOGLE_PRIVATE_KEY=

# Optional fallback only (full JSON encoded as base64):
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# ------------------------------------------------------------
# Public branding (safe for client exposure)
# ------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=What Type Of | Translator

# ------------------------------------------------------------
# Admin bootstrap (used by seed command only)
# ------------------------------------------------------------
ADMIN_SEED_EMAIL=admin@yourdomain.com
ADMIN_SEED_PASSWORD=replace_with_strong_initial_password

# ------------------------------------------------------------
# Usage protection and emergency shutdown
# ------------------------------------------------------------
USAGE_PROTECTION_ENABLED=true
IP_RATE_LIMIT_PER_MINUTE=5
IP_RATE_LIMIT_PER_HOUR=50
IP_RATE_LIMIT_PER_DAY=200
GLOBAL_DAILY_TOKEN_CAP=200000
AUTO_EMERGENCY_SHUTDOWN_ENABLED=true
TRUST_PROXY_HEADERS=true
IP_HASH_SECRET=replace_with_random_secret_min_16_chars

# ------------------------------------------------------------
# Alerting / email (Brevo)
# ------------------------------------------------------------
ALERT_ADMIN_EMAIL=alerts@yourdomain.com
EMAIL_FROM=What Type Of | Translator <translate@whattypeof.com>
BREVO_API_KEY=replace_with_brevo_api_key
